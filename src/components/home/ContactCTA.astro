---
import { site } from '@/lib/site';
import Button from '../ui/Button.astro';
---
<section id="contact" class="container-page py-16 md:py-24">
  <div class="max-w-2xl">
    <span class="eyebrow">Contact</span>
    <h2 class="heading-xl mt-3">Talk to us about your plant.</h2>
    <p class="lede mt-4">Tell us the plant type, capacity, and the chemistry issue you're seeing — we'll come back with a structured next step within one business day.</p>
  </div>

  <div class="mt-12 grid gap-10 lg:grid-cols-[1fr_1.6fr]">
    <div class="rounded-2xl border border-border-hair bg-card p-7 shadow-card">
      <div class="space-y-6">
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-500">Email</p>
          <a href={`mailto:${site.emails.contact}`} class="mt-2 inline-block font-medium text-ink-900 hover:text-accent break-all">{site.emails.contact}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-500">Call</p>
          <a href={`tel:${site.phone.e164}`} class="mt-2 inline-block font-medium text-ink-900 hover:text-accent">{site.phone.display}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-500">Address</p>
          <p class="mt-2 text-ink-700 leading-relaxed">{site.legalEntity}<br>{site.location.city}, {site.location.region}<br>{site.location.country}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-500">Registered</p>
          <p class="mt-2 text-sm text-ink-600">CIN: {site.cin}</p>
        </div>
      </div>
    </div>

    <form
      action={`https://formsubmit.co/${site.emails.contact}`}
      method="POST"
      class="rounded-2xl border border-border-hair bg-card p-7 shadow-card"
    >
      <input type="hidden" name="_subject" value="New enquiry from just-chemicals.com" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value={`${site.url}/?sent=1#contact`} />
      <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-ink-800">Your name</span>
          <input type="text" name="name" required class="mt-1.5 block w-full rounded-lg border border-border-hair bg-canvas px-3 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:border-accent focus:outline-none" placeholder="Jane Engineer" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink-800">Email</span>
          <input type="email" name="email" required class="mt-1.5 block w-full rounded-lg border border-border-hair bg-canvas px-3 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:border-accent focus:outline-none" placeholder="you@plant.com" />
        </label>
      </div>
      <label class="mt-4 block">
        <span class="text-sm font-medium text-ink-800">Subject</span>
        <input type="text" name="subject" required class="mt-1.5 block w-full rounded-lg border border-border-hair bg-canvas px-3 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:border-accent focus:outline-none" placeholder="Boiler audit enquiry, RO troubleshooting…" />
      </label>
      <label class="mt-4 block">
        <span class="text-sm font-medium text-ink-800">Your plant's challenge</span>
        <textarea name="message" rows="5" required class="mt-1.5 block w-full rounded-lg border border-border-hair bg-canvas px-3 py-2.5 text-sm text-ink-900 placeholder:text-ink-400 focus:border-accent focus:outline-none" placeholder="Plant type, capacity, current issue, and what you've tried so far."></textarea>
      </label>

      <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
        <p class="text-xs text-ink-500">We'll respond within one business day.</p>
        <Button type="submit" size="lg">Send Message</Button>
      </div>
    </form>
  </div>
</section>
