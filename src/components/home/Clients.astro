---
<section id="clients" class="bg-mist border-y border-border-hair py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">Clients</span>
      <h2 class="heading-xl mt-3">40+ plants, four industries, three continents of impact.</h2>
      <p class="lede mt-4">A representative list of the utilities, refineries, cement majors, and engineering houses that have engaged Juschem Solutions.</p>
    </div>
    <ul class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {clients.map((c) => (
        <li class="flex items-start gap-3 rounded-lg border border-border-hair bg-card p-4">
          <span class="mt-1 inline-block h-1.5 w-1.5 flex-none rounded-full bg-accent" aria-hidden="true"></span>
          <span class="text-sm text-ink-700">{c}</span>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-xs text-ink-500">Trademarks and copyrights are owned by their respective owners.</p>
  </div>
</section>
