  'JSW Energy Ltd., Ratnagiri',
  'JSW Energy Ltd., Barmer',
  'Reliance Power, Butibori',
  'The Tata Power Co. Ltd., Trombay',
  'Maithon Power Limited (Tata Power)',
  'IOCL Refinery HQ & Haldia Refinery',
  'IOCL Digboi Refinery',
  'IOCL Guwahati',
  'Guru Gobind Singh Refinery',
  'BPCL Kochi Refinery',
  'L&T Power Ltd., Rajpura, Punjab',
  'Lanco Power, Anpara',
  'Bellary Thermal Power Station (KPCL)',
  'Cirebon Power Services, Indonesia',
  'Cambodian Energy Ltd.',
  'Coastal Energen Pvt. Ltd., Tuticorin',
  'Ind-Barath Energy (Utkal) Ltd.',
  'Bengal Energy Ltd.',
  'Industrial Energy Ltd.',
  'CK Birla — Orient Cement Ltd., Chittapur',
  'Dalmia Cement, Ariyalur',
  'Rajshree Cement, Gulbarga (UltraTech)',
  'Sarda Metals and Alloys Limited, Vizangram',
  'Jindal Stainless Ltd.',
  'Continental Carbon India Pvt. Ltd.',
  'RSPL Ltd. (Ghadi Detergent Group)',
  'Kesoram Rayon',
