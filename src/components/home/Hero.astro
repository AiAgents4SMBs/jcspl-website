---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
---
<section id="hero" class="relative overflow-hidden">
  <div class="bg-aurora" aria-hidden="true"></div>
  <div class="container-page relative pt-16 md:pt-24 pb-16 md:pb-24">
    <div class="grid gap-12 lg:grid-cols-[1.15fr_1fr] lg:gap-16 items-center">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <Badge tone="accent">IAPWS · EPRI · VGB aligned</Badge>
          <Badge tone="warm">40+ plants served</Badge>
          <Badge tone="info">Est. 2018 · Bangalore</Badge>
        </div>
        <h1 class="heading-xxl mt-6">
          Power Plant Chemistry That <span class="text-accent">Stops Failures</span> Before They Start.
        </h1>
        <p class="lede mt-6">
          IAPWS/EPRI/VGB-aligned consulting, certified training, and specialty chemicals — trusted by JSW Energy, Tata Power, IOCL, BPCL, Reliance Power, Cirebon Power, and 40+ industrial plants.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button href="#contact" size="lg">Request a Free Diagnostic Call</Button>
          <Button href="#services" variant="secondary" size="lg">Explore Services</Button>
        </div>

        <dl class="mt-10 grid grid-cols-3 max-w-md gap-6">
          <div>
            <dt class="text-xs uppercase tracking-widest text-ink-500">Plants Served</dt>
            <dd class="mt-1 font-display text-2xl md:text-3xl text-ink-900">40+</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-widest text-ink-500">SKUs Catalogued</dt>
            <dd class="mt-1 font-display text-2xl md:text-3xl text-ink-900">42</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-widest text-ink-500">Standards</dt>
            <dd class="mt-1 font-display text-2xl md:text-3xl text-ink-900">IAPWS</dd>
          </div>
        </dl>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-3xl" style="background: linear-gradient(135deg, var(--c-accent-soft), transparent 70%)"></div>
        <div class="relative overflow-hidden rounded-2xl border border-border-hair shadow-lift bg-card">
          <img
            src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?auto=format&fit=crop&w=1600&q=80"
            alt="Industrial power plant with cooling towers"
            width="1600"
            height="1067"
            loading="eager"
            decoding="async"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
        <div class="hidden md:flex absolute -bottom-6 -left-6 items-center gap-3 rounded-2xl bg-card px-4 py-3 shadow-lift border border-border-hair">
          <span class="inline-block h-2 w-2 rounded-full bg-success animate-pulse-dot"></span>
          <span class="text-sm text-ink-700"><strong class="text-ink-900">Live</strong> · taking enquiries</span>
        </div>
      </div>
    </div>
  </div>
</section>
