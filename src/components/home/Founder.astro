---
import Button from '../ui/Button.astro';

const standards = [
  {
    title: 'Cycle Chemistry Aligned',
    body: 'All chemistry programmes referenced against established international cycle-chemistry guidelines for steam-water systems.',
  },
  {
    title: 'EPRI & VGB Standards',
    body: "Audits benchmarked against Electric Power Research Institute and VGB PowerTech guidelines — the same standards used by the world's largest utilities.",
  },
  {
    title: "Juran's Trilogy Methodology",
    body: 'Every engagement uses quality planning, quality control, and quality improvement as a structured framework — not ad-hoc troubleshooting.',
  },
  {
    title: '40+ Plants Served',
    body: 'JSW Energy, Tata Power, IOCL (4 refineries), BPCL, Reliance Power, Cirebon Power, Cambodian Energy, L&T Power, and cement majors.',
  },
];
---
<section id="founder" class="bg-mist border-y border-border-hair py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">Methodology &amp; Expert</span>
      <h2 class="heading-xl mt-3">Our Methodology &amp; Expert</h2>
      <p class="lede mt-4">Standards-based consulting led by a named specialist.</p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[1fr_2fr] items-start">
      <div class="rounded-2xl border border-border-hair bg-card p-7 text-center shadow-card">
        <div class="mx-auto inline-flex h-20 w-20 items-center justify-center rounded-full bg-accent-soft text-accent">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-4.4 0-8 2.7-8 6v2h16v-2c0-3.3-3.6-6-8-6z"/></svg>
        </div>
        <h3 class="mt-4 font-display text-xl text-ink-900">Soumitra Banerjee</h3>
        <p class="mt-1 text-sm text-ink-500">Founder &amp; Chief Technical Officer<br>Juschem Solutions Pvt. Ltd.</p>
        <p class="mt-4 text-sm text-ink-600 leading-relaxed">
          Specialist in power plant chemistry, steam-water cycles, RO systems, and industrial water treatment with decades of plant-side experience across India and Southeast Asia.
        </p>
        <div class="mt-5">
          <Button href="#contact">Talk to Soumitra</Button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {standards.map((s) => (
          <div class="rounded-xl border border-border-hair bg-card p-5">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full bg-success-soft text-success" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <div>
                <h4 class="font-display text-base text-ink-900">{s.title}</h4>
                <p class="mt-1.5 text-sm text-ink-600 leading-relaxed">{s.body}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
