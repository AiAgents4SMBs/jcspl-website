---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'dark';
  size?: 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
  ariaLabel?: string;
  target?: '_blank' | '_self';
  rel?: string;
}
const { href, variant = 'primary', size = 'md', class: cls = '', type = 'button', ariaLabel, target, rel } = Astro.props as Props;
const sizeCls = size === 'lg' ? 'px-6 py-3.5 text-base' : 'px-5 py-2.5 text-sm';
const variantCls = {
  primary: 'bg-accent text-white hover:bg-accent-dark shadow-card',
  secondary: 'bg-card text-ink-900 border border-border-hair hover:border-accent hover:text-accent',
  ghost: 'text-ink-700 hover:text-accent hover:bg-muted',
  dark: 'bg-onyx text-paper hover:bg-onyx-soft shadow-card',
}[variant];
const cn = `inline-flex items-center justify-center gap-1.5 rounded-full font-medium transition-all ${sizeCls} ${variantCls} ${cls}`;
const finalRel = rel ?? (target === '_blank' ? 'noopener noreferrer' : undefined);
---
{href ? (
  <a href={href} class={cn} aria-label={ariaLabel} target={target} rel={finalRel}><slot /></a>
) : (
  <button type={type} class={cn} aria-label={ariaLabel}><slot /></button>
)}
