---
interface Props { question: string; }
const { question } = Astro.props as Props;
---
<details class="group border-b border-border-hair last:border-b-0">
  <summary class="flex cursor-pointer items-start justify-between gap-4 py-5 list-none">
    <span class="font-display text-lg leading-snug text-ink-900">{question}</span>
    <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-muted text-ink-700 transition-transform group-open:rotate-45" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
    </span>
  </summary>
  <div class="pb-6 pr-10 text-ink-600 leading-relaxed"><slot /></div>
</details>
