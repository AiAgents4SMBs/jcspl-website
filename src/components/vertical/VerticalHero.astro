---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

interface Props {
  name: string;
  role: string;
  industryLabel: string;
  tagline: string;
  summary: string;
  accentHex: string;
  accentSoft: string;
  heroImg: string;
  heroAlt: string;
  metrics: { value: string; label: string }[];
}
const { name, role, industryLabel, tagline, summary, accentHex, accentSoft, heroImg, heroAlt, metrics } = Astro.props as Props;
---
<section class="relative overflow-hidden">
  <div class="bg-aurora" aria-hidden="true"></div>
  <div class="container-page relative pt-16 md:pt-24 pb-16 md:pb-24">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16 items-center">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <Badge tone="accent">{role}</Badge>
          <Badge tone="warm">{industryLabel}</Badge>
        </div>
        <h1 class="heading-xxl mt-6">{name}</h1>
        <p class="font-display text-2xl md:text-3xl mt-3 leading-snug" style={`color: ${accentHex}`}>{tagline}</p>
        <p class="lede mt-6">{summary}</p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button href="/contact/" size="lg">Request a Diagnostic Call</Button>
          <Button href="#features" variant="secondary" size="lg">What's included</Button>
        </div>

        {metrics.length > 0 && (
          <dl class="mt-10 grid grid-cols-3 max-w-md gap-6">
            {metrics.map((m) => (
              <div>
                <dt class="text-xs uppercase tracking-widest text-ink-500">{m.label}</dt>
                <dd class="mt-1 font-display text-2xl md:text-3xl text-ink-900">{m.value}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-3xl" style={`background: linear-gradient(135deg, ${accentSoft}, transparent 70%)`}></div>
        <div class="relative overflow-hidden rounded-2xl border border-border-hair shadow-lift bg-card">
          <img
            src={heroImg}
            alt={heroAlt}
            width="1600"
            height="1067"
            loading="eager"
            decoding="async"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
