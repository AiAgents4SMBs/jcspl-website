---
interface Props {
  features: { title: string; description: string }[];
  accentHex: string;
}
const { features, accentHex } = Astro.props as Props;
---
<section id="features" class="container-page py-16 md:py-24">
  <div class="max-w-2xl">
    <span class="eyebrow">What's included</span>
    <h2 class="heading-xl mt-3">Built around plant outcomes, not slide decks.</h2>
    <p class="lede mt-4">Each item below is something we've shipped on a real engagement — not aspirational marketing.</p>
  </div>
  <ul class="mt-12 grid gap-px bg-border-hair rounded-2xl overflow-hidden md:grid-cols-2 lg:grid-cols-3 border border-border-hair">
    {features.map((f) => (
      <li class="bg-card p-7 hover:bg-mist transition-colors">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg" style={`background: ${accentHex}1a; color: ${accentHex}`} aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
          </span>
          <h3 class="font-display text-xl text-ink-900">{f.title}</h3>
        </div>
        <p class="mt-3 text-ink-600 leading-relaxed">{f.description}</p>
      </li>
    ))}
  </ul>
</section>
