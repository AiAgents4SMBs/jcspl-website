---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---
<BaseLayout title="Page not found" noIndex variant="doc">
  <div class="container-page text-center max-w-xl mx-auto">
    <p class="eyebrow">404</p>
    <h1 class="heading-xl mt-3">We couldn't find that page.</h1>
    <p class="lede mt-4 mx-auto">The link may be old or the page may have moved. Try the home page, or jump straight into our chemicals catalogue or training courses.</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <Button href="/" size="lg">Go home</Button>
      <Button href="/chemicals" variant="secondary">Chemicals</Button>
      <Button href="/trainings" variant="secondary">Trainings</Button>
    </div>
  </div>
</BaseLayout>
