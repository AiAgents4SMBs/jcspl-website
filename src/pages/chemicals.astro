  { sr: 18, product: 'MemPro', desc: 'General Antiscalant — Acidic', pack: '25, 35 & 50 Kg' },
  { sr: 19, product: 'MemPro - 3000', desc: 'General Antiscalant — Alkaline', pack: '25, 35 & 50 Kg' },
  { sr: 20, product: 'MemPro - 4000', desc: 'High Sulphate Antiscalant', pack: '25, 35 & 50 Kg' },
  { sr: 21, product: 'MemPro - 5000', desc: 'High CaCO₃, CaSO₄, Iron up to 2.0 ppm & Silica (200 ppm)', pack: '25, 35 & 50 Kg' },
  { sr: 22, product: 'MemPro - 6000', desc: 'High TDS with more than 80% Recovery — Sea Water', pack: '25, 35 & 50 Kg' },
