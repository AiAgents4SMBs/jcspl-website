  { sr: 14, product: 'SigmaTreat - 2425', desc: 'pH Booster cum Sludge Conditioner', pack: '35, 50 Kg' },
  { sr: 15, product: 'SigmaTreat - 3528', desc: 'Inorganic Oxygen Scavenger with Catalyst', pack: '35, 50 Kg' },
  { sr: 16, product: 'SigmaTreat - 3625', desc: 'Organic Oxygen Scavenger — Hydrazine-based', pack: '35, 50 Kg' },
  { sr: 17, product: 'SigmaTreat - 4240', desc: 'Condensate Line Treatment', pack: '35, 50 Kg' },
];

