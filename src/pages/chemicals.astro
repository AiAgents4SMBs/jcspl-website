  { sr: 32, product: 'SigmaFloc - 2410', desc: 'Cationic Poly', pack: '50 Kg' },
  { sr: 33, product: 'SigmaFloc - 6790', desc: 'De-Colour', pack: '50 Kg' },
  { sr: 34, product: 'SigmaFloc - 5210', desc: 'STP Sludge De-watering Poly', pack: '25 Kg Bag' },
  { sr: 35, product: 'SigmaFloc - 1021', desc: 'Chemical Sludge De-watering Poly', pack: '25 Kg Bag' },
  { sr: 36, product: 'SigmaFloc - 5460', desc: 'Chemical Sludge De-watering Poly', pack: '25 Kg Bag' },
