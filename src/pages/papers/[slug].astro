---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { site } from '@/lib/site';

export async function getStaticPaths() {
  const papers = await getCollection('papers', ({ data }) => !data.draft);
  return papers.map((p) => ({ params: { slug: p.id }, props: { paper: p } }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: paper.data.title,
  description: paper.data.summary,
  author: paper.data.authors.map((name) => ({ '@type': 'Person', name })),
  datePublished: paper.data.date.toISOString(),
  publisher: { '@type': 'Organization', name: site.legalEntity, url: site.url },
  keywords: paper.data.keywords.join(', '),
  ...(paper.data.venue ? { isPartOf: { '@type': 'Periodical', name: paper.data.venue } } : {}),
};
---
<BaseLayout
  title={paper.data.title}
  description={paper.data.summary}
  canonicalPath={`/papers/${paper.id}`}
  variant="doc"
  jsonLd={articleLd}
>
  <article class="container-prose">
    <p class="text-xs uppercase tracking-widest text-ink-500">
      {paper.data.venue ?? 'Just-Chemicals'}{paper.data.publishedYear ? ` · ${paper.data.publishedYear}` : ''}
    </p>
    <h1 class="heading-xl mt-2">{paper.data.title}</h1>
    <p class="lede mt-4">{paper.data.summary}</p>
    <p class="mt-3 text-sm text-ink-500">By {paper.data.authors.join(', ')}</p>

    <div class="prose-legal mt-10">
      <Content />
    </div>

    <hr class="my-10 border-border-hair" />
    <p class="text-sm text-ink-600">
      Want this expertise applied to your plant? <a href="/contact/" class="text-accent underline underline-offset-4">Talk to us</a>.
    </p>
  </article>
</BaseLayout>
